# =============================================================================
# .env.example — Restaurants-analytics (Proyecto 2)
# Ejecutá "make setup" para configurar todo automáticamente.
# =============================================================================

# Red Docker del Proyecto 1 — detectada automáticamente por make setup
RE2_NETWORK_NAME=

# Llaves de Airflow — generadas automáticamente por make setup
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# Base de datos interna de analítica
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=analytics

# Neo4J
NEO4J_PASSWORD=Analytics2024!

# Spark
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2
