# =============================================================================
# .env.example — Restaurants-analytics (Proyecto 2)
# Copiá este archivo a .env y completá los valores antes de levantar el stack.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
#  RED DEL PROYECTO 1
#  Docker Compose agrega el nombre del directorio como prefijo al nombre de red.
#  Con el Proyecto 1 levantado, buscá el nombre exacto con:
#      docker network ls | grep re2
#  El resultado suele ser algo como: restaurants-e2_re2_net
# -----------------------------------------------------------------------------
RE2_NETWORK_NAME=restaurants-e2_re2_net

# -----------------------------------------------------------------------------
#  FUENTES DE DATOS — Proyecto 1 (Restaurants-e2)
#  Los nombres de los contenedores son los definidos en el Proyecto 1.
# -----------------------------------------------------------------------------
PG_HOST=re2_postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=restaurants

MONGO_URI=mongodb://re2_mongos:27017/restaurants

# -----------------------------------------------------------------------------
#  BASE DE DATOS INTERNA DE ANALÍTICA
#  Postgres exclusivo para metastore de Hive, Airflow y Metabase.
# -----------------------------------------------------------------------------
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=analytics

# -----------------------------------------------------------------------------
#  APACHE AIRFLOW
#
#  Fernet key — cifra las conexiones guardadas en Airflow.
#  Generá con:
#    python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
#  Secret key — firma las sesiones web.
#  Generá con:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# -----------------------------------------------------------------------------
#  APACHE SPARK
# -----------------------------------------------------------------------------
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# -----------------------------------------------------------------------------
#  NEO4J
#  Mínimo 8 caracteres, al menos una mayúscula y un número o símbolo.
# -----------------------------------------------------------------------------
NEO4J_PASSWORD=Analytics2024!
