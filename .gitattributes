# Forzar LF en todos los archivos de texto para evitar problemas CRLF en Windows
* text=auto eol=lf

# Shell scripts — siempre LF (CRLF rompe bash dentro de contenedores Docker)
*.sh        text eol=lf
*.bash      text eol=lf

# Python y configs
*.py        text eol=lf
*.hql       text eol=lf
*.sql       text eol=lf
*.cypher    text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.conf      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
Makefile    text eol=lf

# Windows scripts — CRLF (PowerShell los prefiere)
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binarios — sin conversión
*.docx      binary
*.xlsx      binary
*.pptx      binary
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.orc       binary
